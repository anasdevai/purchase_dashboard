generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  staff
}

enum ContractStatus {
  Draft
  Completed
  Cancelled
}

enum ContractFileType {
  id_front
  id_back
  device_front
  device_back
  imei_photo
  damage_photo
  accessories_photo
  other
}

enum RepairOrderStatus {
  New
  Received
  InDiagnosis
  WaitingForParts
  SparePartArrived
  InRepair
  Finished
  ReadyForPickup
  Completed
  Cancelled
}

enum SparePartStatus {
  NotOrdered
  Ordered
  Arrived
  Installed
}

enum InvoicePaymentMethod {
  Cash
  BankTransfer
  Card
  PayPal
  Other
}

enum InvoicePaymentStatus {
  Draft
  Open
  Sent
  Paid
  PartiallyPaid
  Overdue
  Cancelled
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String        @map("password_hash")
  role         UserRole      @default(staff)
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  contracts       Contract[]
  repairOrders    RepairOrder[]   @relation("UserRepairs")
  invoices        Invoice[]
  shopSettings    ShopSettings?
  repairCompanies RepairCompany[]
  customers       Customer[]
  assignedRepairs RepairOrder[]   @relation("AssignedEmployeeRepairs")
  quotations      Quotation[]     @relation("UserQuotations")
  assignedQuotations Quotation[]   @relation("EmployeeQuotations")
  assignedInvoices   Invoice[]     @relation("EmployeeInvoices")
  smtpSettings       SmtpSettings?
  imapSettings       ImapSettings?
  emailTemplates     EmailTemplate[]
  emailLogs          EmailLog[]
  appointments       Appointment[]
  googleAccessToken  String?       @map("google_access_token")
  googleRefreshToken String?       @map("google_refresh_token")
  googleTokenExpiry  DateTime?     @map("google_token_expiry")
  suppliers          Supplier[]
  spareParts         SparePart[]
  inventoryOrders    InventoryOrder[]
  goodsReceipts      GoodsReceipt[]
  stockAdjustments   StockAdjustment[]
  repairRequests     RepairRequest[]

  @@map("users")
}

model ShopSettings {
  id                        String   @id @default(uuid())
  userId                    String   @unique @map("user_id")
  shopName                  String   @default("") @map("shop_name")
  shopAddress               String   @default("") @map("shop_address")
  street                    String   @default("") @map("street")
  zipCode                   String   @default("") @map("zip_code")
  city                      String   @default("") @map("city")
  country                   String   @default("") @map("country")
  shopPhone                 String   @default("") @map("shop_phone")
  shopEmail                 String   @default("") @map("shop_email")
  website                   String   @default("") @map("website")
  ownerName                 String   @default("") @map("owner_name")
  vatNumber                 String   @default("") @map("vat_number")
  companyRegistrationNumber String   @default("") @map("company_registration_number")
  taxNumber                 String   @default("") @map("tax_number")
  accountHolder             String   @default("") @map("account_holder")
  iban                      String   @default("") @map("iban")
  bicSwift                  String   @default("") @map("bic_swift")
  bankName                  String   @default("") @map("bank_name")
  defaultVatRate            String   @default("20") @map("default_vat_rate")
  defaultVatCustom          String   @default("") @map("default_vat_custom")
  logoDataUrl               String?  @map("logo_data_url")
  widgetPrimaryColor        String   @default("#0284c7") @map("widget_primary_color")
  widgetAccentColor         String   @default("#0f172a") @map("widget_accent_color")
  widgetFont                String   @default("Inter") @map("widget_font")
  widgetShowLogo            Boolean  @default(true) @map("widget_show_logo")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shop_settings")
}

model Contract {
  id                      String         @id @default(uuid())
  userId                  String         @map("user_id")
  contractNumber          String         @map("contract_number")
  salutation              String?        @map("salutation")
  customerFirstName       String?        @map("customer_first_name")
  customerLastName        String?        @map("customer_last_name")
  customerName            String?        @map("customer_name")
  customerAddress         String?        @map("customer_address")
  customerStreet          String?        @map("customer_street")
  customerZipCode         String?        @map("customer_zip_code")
  customerCity            String?        @map("customer_city")
  customerPhone           String?        @map("customer_phone")
  customerEmail           String?        @map("customer_email")
  customerDateOfBirth     DateTime?      @map("customer_date_of_birth") @db.Date
  idDocumentNumber        String?        @map("id_document_number")
  idType                  String?        @map("id_type")
  deviceType              String?        @map("device_type")
  brand                   String?
  model                   String?
  imei                    String?
  serialNumber            String?        @map("serial_number")
  storage                 String?
  color                   String?
  condition               String?
  accessories             String?
  batteryHealth           String?        @map("battery_health")
  osVersion               String?        @map("os_version")
  icloudStatus            String?        @map("icloud_status")
  mdmStatus               String?        @map("mdm_status")
  warranty                String?
  purchaseReceiptAvailable Boolean?      @default(false) @map("purchase_receipt_available")
  damageNotes             String?        @map("damage_notes")
  internalNotes           String?        @map("internal_notes")
  purchasePrice           Decimal?       @map("purchase_price") @db.Decimal(12, 2)
  paymentMethod           String?        @map("payment_method")
  paymentStatus           String?        @map("payment_status")
  notes                   String?        @map("notes")
  signatureToken          String?        @map("signature_token")
  signatureStatus         String?        @map("signature_status")
  ownershipConfirmed      Boolean        @default(false) @map("ownership_confirmed")
  notStolenConfirmed      Boolean        @default(false) @map("not_stolen_confirmed")
  icloudRemoved           Boolean        @default(false) @map("icloud_removed")
  googleLockRemoved       Boolean        @default(false) @map("google_lock_removed")
  otherLockRemoved        Boolean        @default(false) @map("other_lock_removed")
  factoryResetConfirmed   Boolean        @default(false) @map("factory_reset_confirmed")
  signaturePath           String?        @map("signature_path")
  shopkeeperSignaturePath String?        @map("shopkeeper_signature_path")
  pdfPath                 String?        @map("pdf_path")
  status                  ContractStatus @default(Draft)
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")
  user                    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId              String?        @map("customer_id")
  customer                Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  files                   ContractFile[]

  @@unique([userId, contractNumber])
  @@index([userId])
  @@index([contractNumber])
  @@index([customerName])
  @@index([customerPhone])
  @@index([imei])
  @@index([serialNumber])
  @@index([model])
  @@index([createdAt])
  @@index([signatureToken])
  @@map("contracts")
}

model ContractFile {
  id         String           @id @default(uuid())
  contractId String           @map("contract_id")
  fileType   ContractFileType @map("file_type")
  filePath   String           @map("file_path")
  createdAt  DateTime         @default(now()) @map("created_at")
  contract   Contract         @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@unique([contractId, fileType, filePath])
  @@map("contract_files")
}

model RepairOrder {
  id                     String            @id @default(uuid())
  userId                 String            @map("user_id")
  repairOrderNumber      String            @map("repair_order_number")
  customerName           String            @map("customer_name")
  customerPhone          String            @map("customer_phone")
  customerEmail          String?           @map("customer_email")
  customerAddress        String?           @map("customer_address")
  deviceType             String            @map("device_type")
  brand                  String?
  model                  String
  imeiOrSerial           String?           @map("imei_or_serial")
  passwordPin            String?           @map("password_pin")
  accessoriesReceived    String?           @map("accessories_received")
  problemDescription     String            @map("problem_description")
  issueCategory          String?           @map("issue_category")
  diagnosis              String?           @map("diagnosis")
  requiredSpareParts     String?           @map("required_spare_parts")
  sparePartStatus        SparePartStatus?  @map("spare_part_status")
  visibleDamage          String?           @map("visible_damage")
  technicianNotes        String?           @map("technician_notes")
  estimatedPrice         Decimal?          @map("estimated_price") @db.Decimal(12, 2)
  discountPercent        Decimal?          @map("discount_percent") @db.Decimal(5, 2)
  depositAmount          Decimal?          @map("deposit_amount") @db.Decimal(12, 2)
  paymentMethod          String?           @map("payment_method")
  expectedCompletionDate DateTime?         @map("expected_completion_date") @db.Date
  status                 RepairOrderStatus @default(Received)
  pdfPath                String?           @map("pdf_path")
  repairCompanyId        String?           @map("repair_company_id")
  repairCompanyNotes     String?           @map("repair_company_notes")
  assignedEmployeeId     String?           @map("assigned_employee_id")
  customerId             String?           @map("customer_id")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  user                   User              @relation("UserRepairs", fields: [userId], references: [id], onDelete: Cascade)
  invoices               Invoice[]
  repairCompany          RepairCompany?    @relation(fields: [repairCompanyId], references: [id], onDelete: SetNull)
  history                RepairOrderHistory[]
  assignedEmployee       User?             @relation("AssignedEmployeeRepairs", fields: [assignedEmployeeId], references: [id], onDelete: SetNull)
  customer               Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  quotationId            String?           @map("quotation_id")
  quotation              Quotation?        @relation("QuotationRepairOrders", fields: [quotationId], references: [id], onDelete: SetNull)
  appointments           Appointment[]

  @@unique([userId, repairOrderNumber])
  @@index([userId])
  @@index([repairOrderNumber])
  @@index([customerName])
  @@index([customerPhone])
  @@index([model])
  @@index([imeiOrSerial])
  @@index([status])
  @@index([createdAt])
  @@index([repairCompanyId])
  @@index([assignedEmployeeId])
  @@index([customerId])
  @@map("repair_orders")
}

model Invoice {
  id                   String                @id @default(uuid())
  userId               String                @map("user_id")
  repairOrderId        String?               @map("repair_order_id")
  invoiceNumber        String                @map("invoice_number")
  invoiceDate          DateTime              @default(now()) @map("invoice_date") @db.Date
  customerName         String                @map("customer_name")
  customerAddress      String?               @map("customer_address")
  customerPhone        String?               @map("customer_phone")
  customerEmail        String?               @map("customer_email")
  deviceSummary        String?               @map("device_summary")
  repairSummary        String?               @map("repair_summary")
  paymentMethod        InvoicePaymentMethod? @map("payment_method")
  paymentStatus        InvoicePaymentStatus? @map("payment_status")
  calculatedNetAmount  Decimal               @default(0) @map("calculated_net_amount") @db.Decimal(12, 2)
  calculatedVatAmount  Decimal               @default(0) @map("calculated_vat_amount") @db.Decimal(12, 2)
  calculatedGrossTotal Decimal               @default(0) @map("calculated_gross_total") @db.Decimal(12, 2)
  netAmountOverride    Decimal?              @map("net_amount_override") @db.Decimal(12, 2)
  vatAmountOverride    Decimal?              @map("vat_amount_override") @db.Decimal(12, 2)
  grossTotalOverride   Decimal?              @map("gross_total_override") @db.Decimal(12, 2)
  notes                String?
  pdfPath              String?               @map("pdf_path")
  serviceDate          DateTime?             @map("service_date") @db.Date
  dueDate              DateTime?             @map("due_date") @db.Date
  paymentDate          DateTime?             @map("payment_date") @db.Date
  paymentReference     String?               @map("payment_reference")
  cancellationReason   String?               @map("cancellation_reason")
  employeeId           String?               @map("employee_id")
  employee             User?                 @relation("EmployeeInvoices", fields: [employeeId], references: [id], onDelete: SetNull)
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId           String?               @map("customer_id")
  customer             Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  repairOrder          RepairOrder?          @relation(fields: [repairOrderId], references: [id], onDelete: SetNull)
  items                InvoiceItem[]

  @@unique([userId, invoiceNumber])
  @@index([userId])
  @@index([repairOrderId])
  @@index([invoiceNumber])
  @@index([customerName])
  @@index([customerPhone])
  @@index([invoiceDate])
  @@index([createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String   @map("invoice_id")
  description String
  quantity    Decimal  @db.Decimal(12, 2)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  vatPercent  Decimal  @map("vat_percent") @db.Decimal(5, 2)
  lineNet     Decimal  @map("line_net") @db.Decimal(12, 2)
  lineVat     Decimal  @map("line_vat") @db.Decimal(12, 2)
  lineTotal   Decimal  @map("line_total") @db.Decimal(12, 2)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model RepairCompany {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  name         String
  contactInfo  String?       @map("contact_info")
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  repairOrders RepairOrder[]

  @@unique([userId, name])
  @@index([userId])
  @@map("repair_companies")
}

model RepairOrderHistory {
  id            String             @id @default(uuid())
  repairOrderId String             @map("repair_order_id")
  userId        String             @map("user_id")
  employeeName  String             @map("employee_name")
  fromStatus    RepairOrderStatus? @map("from_status")
  toStatus      RepairOrderStatus  @map("to_status")
  comment       String?
  createdAt     DateTime           @default(now()) @map("created_at")
  repairOrder   RepairOrder        @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)

  @@index([repairOrderId])
  @@index([createdAt])
  @@map("repair_order_history")
}

model Customer {
  id             String          @id @default(uuid())
  userId         String          @map("user_id")
  customerNumber String?         @map("customer_number")
  salutation     String?
  firstName      String?         @map("first_name")
  lastName       String?         @map("last_name")
  company        String?
  vatId          String?         @map("vat_id")
  street         String?
  zipCode        String?         @map("zip_code")
  city           String?
  dateOfBirth    DateTime?       @map("date_of_birth") @db.Date
  newsletter     Boolean         @default(false)
  notes          String?         @db.Text
  name           String
  phone          String
  email          String?
  address        String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  repairOrders   RepairOrder[]
  quotations     Quotation[]
  contracts      Contract[]
  invoices       Invoice[]
  appointments   Appointment[]

  @@unique([userId, name, phone])
  @@unique([userId, customerNumber])
  @@index([userId])
  @@index([name])
  @@index([phone])
  @@map("customers")
}

enum QuotationStatus {
  Draft
  Sent
  Accepted
  Rejected
  Expired
}

model Quotation {
  id              String          @id @default(uuid())
  userId          String          @map("user_id")
  quotationNumber String          @map("quotation_number")
  validUntilDate  DateTime        @map("valid_until_date") @db.Date
  status          QuotationStatus @default(Draft)
  
  employeeId      String?         @map("employee_id")
  
  customerId      String?         @map("customer_id")
  customerName    String          @map("customer_name")
  customerPhone   String          @map("customer_phone")
  customerEmail   String?         @map("customer_email")
  customerAddress String?         @map("customer_address")
  
  deviceType      String          @map("device_type")
  brand           String?
  model           String
  imeiOrSerial    String?         @map("imei_or_serial")
  
  pdfPath         String?         @map("pdf_path")
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  
  user            User            @relation("UserQuotations", fields: [userId], references: [id], onDelete: Cascade)
  employee        User?           @relation("EmployeeQuotations", fields: [employeeId], references: [id], onDelete: SetNull)
  customer        Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items           QuotationItem[]
  repairOrders    RepairOrder[]   @relation("QuotationRepairOrders")

  @@unique([userId, quotationNumber])
  @@index([userId])
  @@index([quotationNumber])
  @@index([customerName])
  @@index([customerPhone])
  @@index([model])
  @@index([createdAt])
  @@map("quotations")
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String    @map("quotation_id")
  repairType  String    @map("repair_type")
  description String
  unitPrice   Decimal   @map("unit_price") @db.Decimal(12, 2)
  quantity    Decimal   @default(1) @db.Decimal(12, 2)
  discount    Decimal?  @db.Decimal(5, 2)
  lineTotal   Decimal   @map("line_total") @db.Decimal(12, 2)
  createdAt   DateTime  @default(now()) @map("created_at")
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@map("quotation_items")
}

model SmtpSettings {
  id         String   @id @default(uuid())
  userId     String   @unique @map("user_id")
  host       String
  port       Int
  encryption String   @default("none")
  username   String
  password   String   @map("encrypted_password")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("smtp_settings")
}

model ImapSettings {
  id         String   @id @default(uuid())
  userId     String   @unique @map("user_id")
  host       String
  port       Int
  encryption String   @default("none")
  username   String
  password   String   @map("encrypted_password")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("imap_settings")
}

model EmailTemplate {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  subject   String
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("email_templates")
}

model EmailLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  to        String
  subject   String
  body      String   @db.Text
  status    String
  error     String?  @db.Text
  sentAt    DateTime @default(now()) @map("sent_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sentAt])
  @@map("email_logs")
}

enum AppointmentStatus {
  Booked
  Confirmed
  Arrived
  Cancelled
  Voided
}

enum AppointmentSource {
  Manual
  Order
  Website
}

model Appointment {
  id            String            @id @default(uuid())
  userId        String            @map("user_id")
  title         String
  customerId    String?           @map("customer_id")
  deviceBrand   String?           @map("device_brand")
  deviceModel   String?           @map("device_model")
  deviceImei    String?           @map("device_imei")
  repairOrderId String?           @map("repair_order_id")
  startTime     DateTime          @map("start_time")
  endTime       DateTime          @map("end_time")
  duration      Int
  note          String?           @db.Text
  status        AppointmentStatus @default(Booked)
  source        AppointmentSource @default(Manual)
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  googleCalendarEventId String?           @map("google_calendar_event_id")

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer      Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  repairOrder   RepairOrder?      @relation(fields: [repairOrderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([customerId])
  @@index([repairOrderId])
  @@index([startTime])
  @@map("appointments")
}

enum RepairCategory {
  Display
  Battery
  WaterDamage
  Software
  LogicBoard
  Camera
  ChargingPort
  Keyboard
  Other
}

enum DifficultyLevel {
  Easy
  Medium
  Difficult
  Expert
}

model Brand {
  id          String       @id @default(uuid())
  name        String       @unique
  logoUrl     String?      @map("logo_url")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deviceTypes DeviceType[]
  models      Model[]

  @@map("brands")
}

model DeviceType {
  id        String   @id @default(uuid())
  name      String
  brandId   String   @map("brand_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  models    Model[]

  @@unique([brandId, name])
  @@map("device_types")
}

model Model {
  id             String      @id @default(uuid())
  name           String
  deviceTypeId   String      @map("device_type_id")
  brandId        String      @map("brand_id")
  generation     String?
  storageOptions String[]    @map("storage_options")
  colorOptions   String[]    @map("color_options")
  releaseYear    Int?        @map("release_year")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deviceType     DeviceType  @relation(fields: [deviceTypeId], references: [id], onDelete: Cascade)
  brand          Brand       @relation(fields: [brandId], references: [id], onDelete: Cascade)
  priceLists     PriceList[]

  @@map("models")
}

model RepairType {
  id            String          @id @default(uuid())
  name          String
  category      RepairCategory
  standardPrice Decimal?        @map("standard_price") @db.Decimal(12, 2)
  duration      Int?
  difficulty    DifficultyLevel?
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  priceLists    PriceList[]

  @@map("repair_types")
}

model PriceList {
  id           String     @id @default(uuid())
  modelId      String     @map("model_id")
  repairTypeId String     @map("repair_type_id")
  price        Decimal    @db.Decimal(12, 2)
  duration     Int?
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  model        Model      @relation(fields: [modelId], references: [id], onDelete: Cascade)
  repairType   RepairType @relation(fields: [repairTypeId], references: [id], onDelete: Cascade)

  @@unique([modelId, repairTypeId])
  @@map("price_lists")
}

model Supplier {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  companyName   String           @map("company_name")
  contactPerson String?          @map("contact_person")
  phone         String?
  email         String
  website       String?
  deliveryTime  Int?             @map("delivery_time")
  paymentTerms  String?          @map("payment_terms")
  isActive      Boolean          @default(true) @map("is_active")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  spareParts    SparePart[]
  orders        InventoryOrder[]

  @@unique([userId, companyName])
  @@index([userId])
  @@map("suppliers")
}

model SparePart {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  itemNumber      String            @map("item_number")
  name            String
  category        String
  compatibility   String
  stock           Int               @default(0)
  minimumStock    Int               @default(0) @map("minimum_stock")
  supplierId      String?           @map("supplier_id")
  purchasePrice   Decimal           @map("purchase_price") @db.Decimal(12, 2)
  salePrice       Decimal           @map("sale_price") @db.Decimal(12, 2)
  storageLocation String?           @map("storage_location")
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplier        Supplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  orderItems      InventoryOrderItem[]
  adjustments     StockAdjustment[]

  @@unique([userId, itemNumber])
  @@index([userId])
  @@index([supplierId])
  @@map("spare_parts")
}

enum InventoryOrderStatus {
  Ordered
  Shipped
  PartiallyDelivered
  Delivered
  Cancelled
}

model InventoryOrder {
  id            String               @id @default(uuid())
  userId        String               @map("user_id")
  orderNumber   String               @map("order_number")
  supplierId    String               @map("supplier_id")
  orderDate     DateTime             @default(now()) @map("order_date")
  expectedDate  DateTime?            @map("expected_date")
  status        InventoryOrderStatus @default(Ordered)
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplier      Supplier             @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items         InventoryOrderItem[]
  goodsReceipts GoodsReceipt[]

  @@unique([userId, orderNumber])
  @@index([userId])
  @@index([supplierId])
  @@map("inventory_orders")
}

model InventoryOrderItem {
  id               String         @id @default(uuid())
  orderId          String         @map("order_id")
  sparePartId      String         @map("spare_part_id")
  quantityOrdered  Int            @map("quantity_ordered")
  quantityReceived Int            @default(0) @map("quantity_received")

  order            InventoryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sparePart        SparePart      @relation(fields: [sparePartId], references: [id], onDelete: Restrict)

  @@unique([orderId, sparePartId])
  @@index([orderId])
  @@index([sparePartId])
  @@map("inventory_order_items")
}

model GoodsReceipt {
  id            String         @id @default(uuid())
  userId        String         @map("user_id")
  orderId       String         @map("order_id")
  receivedDate  DateTime       @default(now()) @map("received_date")
  notes         String?
  createdAt     DateTime       @default(now()) @map("created_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  order         InventoryOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([orderId])
  @@map("goods_receipts")
}

model StockAdjustment {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  sparePartId  String    @map("spare_part_id")
  quantityDiff Int       @map("quantity_diff")
  reason       String
  createdAt    DateTime  @default(now()) @map("created_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sparePart    SparePart @relation(fields: [sparePartId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sparePartId])
  @@map("stock_adjustments")
}

enum RepairRequestStatus {
  New
  Seen
  Contacted
  Completed
}

model RepairRequest {
  id                   String              @id @default(uuid())
  userId               String              @map("user_id")
  customerName         String              @map("customer_name")
  customerEmail        String              @map("customer_email")
  customerPhone        String              @map("customer_phone")
  deviceBrand          String              @map("device_brand")
  deviceType           String              @map("device_type")
  deviceModel          String              @map("device_model")
  repairType           String              @map("repair_type")
  issueDescription     String              @db.Text @map("issue_description")
  photoPath            String?             @map("photo_path")
  preferredAppointment DateTime?           @map("preferred_appointment")
  status               RepairRequestStatus @default(New)
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  customerCreatedId    String?             @map("customer_created_id")
  repairOrderCreatedId String?             @map("repair_order_created_id")

  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("repair_requests")
}



