generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContractStatus {
  Draft
  Completed
  Cancelled
}

enum ContractFileType {
  id_front
  id_back
  device_front
  device_back
  imei_photo
  damage_photo
  accessories_photo
  other
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String        @map("password_hash")
  createdAt    DateTime      @default(now()) @map("created_at")
  contracts    Contract[]
  shopSettings ShopSettings?

  @@map("users")
}

model ShopSettings {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  shopName    String   @default("") @map("shop_name")
  shopAddress String   @default("") @map("shop_address")
  shopPhone   String   @default("") @map("shop_phone")
  shopEmail   String   @default("") @map("shop_email")
  ownerName   String   @default("") @map("owner_name")
  logoDataUrl String?  @map("logo_data_url")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shop_settings")
}

model Contract {
  id                      String         @id @default(uuid())
  userId                  String         @map("user_id")
  contractNumber          String         @map("contract_number")
  customerName            String?        @map("customer_name")
  customerAddress         String?        @map("customer_address")
  customerPhone           String?        @map("customer_phone")
  customerEmail           String?        @map("customer_email")
  customerDateOfBirth     DateTime?      @map("customer_date_of_birth") @db.Date
  idDocumentNumber        String?        @map("id_document_number")
  deviceType              String?        @map("device_type")
  brand                   String?
  model                   String?
  imei                    String?
  serialNumber            String?        @map("serial_number")
  storage                 String?
  color                   String?
  condition               String?
  accessories             String?
  batteryHealth           String?        @map("battery_health")
  damageNotes             String?        @map("damage_notes")
  internalNotes           String?        @map("internal_notes")
  purchasePrice           Decimal?       @map("purchase_price") @db.Decimal(12, 2)
  paymentMethod           String?        @map("payment_method")
  ownershipConfirmed      Boolean        @default(false) @map("ownership_confirmed")
  notStolenConfirmed      Boolean        @default(false) @map("not_stolen_confirmed")
  icloudRemoved           Boolean        @default(false) @map("icloud_removed")
  googleLockRemoved       Boolean        @default(false) @map("google_lock_removed")
  otherLockRemoved        Boolean        @default(false) @map("other_lock_removed")
  factoryResetConfirmed   Boolean        @default(false) @map("factory_reset_confirmed")
  signaturePath           String?        @map("signature_path")
  shopkeeperSignaturePath String?        @map("shopkeeper_signature_path")
  pdfPath                 String?        @map("pdf_path")
  status                  ContractStatus @default(Draft)
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")
  user                    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  files                   ContractFile[]

  @@unique([userId, contractNumber])
  @@index([userId])
  @@index([contractNumber])
  @@index([customerName])
  @@index([customerPhone])
  @@index([imei])
  @@index([serialNumber])
  @@index([model])
  @@index([createdAt])
  @@map("contracts")
}

model ContractFile {
  id         String           @id @default(uuid())
  contractId String           @map("contract_id")
  fileType   ContractFileType @map("file_type")
  filePath   String           @map("file_path")
  createdAt  DateTime         @default(now()) @map("created_at")
  contract   Contract         @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@unique([contractId, fileType, filePath])
  @@map("contract_files")
}
