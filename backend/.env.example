# PostgreSQL connection (create the database in pgAdmin, then set this URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?schema=public"
JWT_SECRET="change-this-secret-before-running"

NODE_ENV=development

# Listen on all interfaces so phones/laptops on the same WiFi can reach the API.
HOST=0.0.0.0
PORT=4000

# Comma-separated browser origins allowed to call the API (required with credentials).
# Local development (Vite on 5173 or Docker frontend on 3001):
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3001,http://127.0.0.1:3001

# Public frontend URL used in email links and OAuth redirects.
# Production example: FRONTEND_URL=https://scleraai.tail9bdf21.ts.net
FRONTEND_URL=http://localhost:5173

# Allow Vite dev server on private LAN IPs during local development only.
# Set to false in production.
CORS_ALLOW_LAN=true

# Google Calendar OAuth callback (must match Google Cloud console redirect URI).
# Local: GOOGLE_REDIRECT_URI=http://localhost:4000/api/appointments/google/callback
# Production: GOOGLE_REDIRECT_URI=https://your-host/api/appointments/google/callback
GOOGLE_REDIRECT_URI=http://localhost:4000/api/appointments/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SHOP_NAME="Sceleria"
SHOP_ADDRESS="Your shop address"
SHOP_PHONE="Your shop phone"
SHOP_EMAIL="Your shop email"
SHOP_OWNER_NAME="Your owner / manager name"
SHOP_LOGO_PATH=""
MAX_UPLOAD_SIZE_MB=5

# SMTP (use MailHog/Mailpit on port 1025 for local development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sclera.io

# Gemini OCR (repair order form scan)
GEMINI_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-2.5-flash

# After migrations, seed a local dev admin (npm run seed):
# admin@example.com / Admin123456 — development only, never use in production.
