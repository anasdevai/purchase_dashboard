# PostgreSQL connection (create the database in pgAdmin, then set this URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?schema=public"
JWT_SECRET="change-this-secret-before-running"

# Listen on all interfaces so phones/laptops on the same WiFi can reach the API.
HOST=0.0.0.0
PORT=4000

# Always allow localhost. Add your LAN IP if you prefer an explicit list:
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.50:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Allow Vite dev server on private LAN IPs (192.168.x.x, 10.x.x.x, etc.) on port 5173.
CORS_ALLOW_LAN=true

SHOP_NAME="Sceleria"
SHOP_ADDRESS="Your shop address"
SHOP_PHONE="Your shop phone"
SHOP_EMAIL="Your shop email"
SHOP_OWNER_NAME="Your owner / manager name"
SHOP_LOGO_PATH=""
MAX_UPLOAD_SIZE_MB=5
