# PostgreSQL connection
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?schema=public"
JWT_SECRET="change-this-secret-before-running"

HOST=0.0.0.0
PORT=4000
NODE_ENV=production

# Public URL of the frontend (no trailing slash). Used for CORS, email links, OAuth redirects.
FRONTEND_URL=https://scleraai.tail9bdf21.ts.net

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=https://scleraai.tail9bdf21.ts.net
CORS_ALLOW_LAN=false

# Google Calendar OAuth callback (defaults to FRONTEND_URL + /api/appointments/google/callback)
GOOGLE_REDIRECT_URI=https://scleraai.tail9bdf21.ts.net/api/appointments/google/callback

# Gemini OCR (optional)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=

SHOP_NAME="Sceleria"
SHOP_ADDRESS="Your shop address"
SHOP_PHONE="Your shop phone"
SHOP_EMAIL="Your shop email"
SHOP_OWNER_NAME="Your owner / manager name"
SHOP_LOGO_PATH=""
MAX_UPLOAD_SIZE_MB=5
