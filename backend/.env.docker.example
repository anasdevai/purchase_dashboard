# Copy to backend/.env before: docker compose up -d
#
# PostgreSQL (must match database/docker-compose.yml service name)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin123
POSTGRES_DB=purchase_dashboard
POSTGRES_HOST=purchase_dashboard_postgres
DATABASE_URL=postgresql://postgres:admin123@purchase_dashboard_postgres:5432/purchase_dashboard?schema=public

BACKEND_PORT=4000
JWT_SECRET=change-this-secret-before-running
NODE_ENV=production

# Public frontend URL (Tailscale / domain — no trailing slash)
FRONTEND_URL=https://scleraai.tail9bdf21.ts.net
CORS_ORIGINS=https://scleraai.tail9bdf21.ts.net
CORS_ALLOW_LAN=false

GOOGLE_REDIRECT_URI=https://scleraai.tail9bdf21.ts.net/api/appointments/google/callback

SHOP_NAME=Sceleria
SHOP_ADDRESS=Your shop address
SHOP_PHONE=Your shop phone
SHOP_EMAIL=Your shop email
SHOP_OWNER_NAME=Your owner / manager name
MAX_UPLOAD_SIZE_MB=20

PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
