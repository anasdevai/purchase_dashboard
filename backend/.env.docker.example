# PostgreSQL (must match database/docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin123
POSTGRES_DB=purchase_dashboard
POSTGRES_HOST=purchase_dashboard_postgres

# Backend
BACKEND_PORT=4000
JWT_SECRET=change-this-secret-before-running
CORS_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1,http://127.0.0.1:80,http://YOUR_SERVER_IP,http://YOUR_SERVER_IP:80

# Shop defaults (optional)
SHOP_NAME=Sceleria
SHOP_ADDRESS=Your shop address
SHOP_PHONE=Your shop phone
SHOP_EMAIL=Your shop email
SHOP_OWNER_NAME=Your owner / manager name
MAX_UPLOAD_SIZE_MB=20
