# Copy to backend/.env before: docker compose up -d
#
# PostgreSQL (must match database/docker-compose.yml service name)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin123
POSTGRES_DB=purchase_dashboard
POSTGRES_HOST=purchase_dashboard_postgres
DATABASE_URL=postgresql://postgres:admin123@purchase_dashboard_postgres:5432/purchase_dashboard?schema=public

# Backend
BACKEND_PORT=4000
JWT_SECRET=change-this-secret-before-running

# Browser origins allowed to call the API (must include your deployed frontend URL).
# Add both http and https if you use Nginx Proxy Manager with SSL.
CORS_ORIGINS=https://purchasedevice.cybrain.at,http://purchasedevice.cybrain.at,http://100.98.57.25:3001
CORS_ALLOW_LAN=false

# Shop defaults (optional)
SHOP_NAME=Sceleria
SHOP_ADDRESS=Your shop address
SHOP_PHONE=Your shop phone
SHOP_EMAIL=Your shop email
SHOP_OWNER_NAME=Your owner / manager name
MAX_UPLOAD_SIZE_MB=20

# PDF generation (Docker/Alpine uses system Chromium)
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
