# Production (Tailscale / public host — API at /api via reverse proxy or nginx in frontend container):
# VITE_API_URL=https://scleraai.tail9bdf21.ts.net/api
#
# Local development (Vite dev server):
VITE_API_URL=http://localhost:4000/api
#
# Legacy alias (origin only, without /api):
# VITE_API_BASE_URL=http://localhost:4000
#
# Docker: if frontend nginx proxies /api to the backend, leave VITE_API_* unset —
# the app uses window.location.origin automatically in production.
