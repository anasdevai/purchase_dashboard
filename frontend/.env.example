# API URL for this PC only (npm run dev on the same machine):
VITE_API_BASE_URL=http://localhost:4000

# LAN testing from phones/other laptops on the same WiFi — replace with your PC's IPv4
# (shown as "Network:" when you run `npm run dev` in the frontend folder):
# VITE_API_BASE_URL=http://192.168.1.50:4000
#
# If VITE_API_BASE_URL is unset during `npm run dev`, opening the UI via a private
# LAN IP auto-targets http://<LAN_IP>:4000. Production Docker builds must set
# VITE_API_BASE_URL explicitly (see .env.docker.example).
