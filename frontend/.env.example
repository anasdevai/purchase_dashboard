# Backend API URL (include /api suffix).
# Local development:
VITE_API_URL=http://localhost:4000/api

# Production example (same host reverse-proxy):
# VITE_API_URL=https://scleraai.tail9bdf21.ts.net/api

# Legacy alias (still supported, without /api suffix):
# VITE_API_BASE_URL=http://localhost:4000

# LAN testing from phones/other laptops on the same WiFi:
# VITE_API_URL=http://192.168.1.50:4000/api
#
# If VITE_API_URL is unset during `npm run dev`, opening the UI via a private LAN IP
# auto-targets http://<LAN_IP>:4000. Production builds must set VITE_API_URL explicitly.
