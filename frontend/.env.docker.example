# Browser must reach this backend URL (your server IP or domain)
# VITE_API_BASE_URL=http://localhost:4000
VITE_API_BASE_URL=http://100.98.57.25:4000

# Copy to frontend/.env before: docker compose build && docker compose up -d
#
# Public URL the browser uses to reach the API (not a Docker internal hostname).
# Examples:
#   API on host port 4000:  https://purchasedevice.cybrain.at:4000
#   API behind reverse proxy: https://api.purchasedevice.cybrain.at
#   Same domain /api proxy:   https://purchasedevice.cybrain.at
# VITE_API_BASE_URL=https://purchasedevice.cybrain.at:4000

# Host port published for the frontend container (nginx listens on 80 inside).
FRONTEND_PORT=80
